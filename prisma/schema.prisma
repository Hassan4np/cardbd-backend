datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}


model User {
  id           Int       @id @default(autoincrement())
  name         String
  email        String    @unique
  phone        String?
  passwordHash String
  role         String    @default("user") // "user" or "admin"
  address      String?
  orders       Order[]
  reviews      Review[]
  createdAt    DateTime  @default(now())

  @@map("users")
}

model Category {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  img      String?
  products Product[]

  @@map("categories")
}

model Product {
  id            Int            @id @default(autoincrement())
  title         String
  subtitle      String?
  price         Float
  oldPrice      Float?
  brand         String         @default("Non-Brand")
  discount      Int            @default(0)
  offer         Int            @default(0)
  rating        Float          @default(0.0)
  des           String?
  reviewCount   Int            @default(0)
  questionCount Int            @default(0)
  sold          Int            @default(0)
  badge         String? // e.g., "FLASH SALE"
  endsIn        String? // e.g., "02:14:37"
  img           String // Main Image
  categoryId    Int?
  category      Category?      @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  subImages     ProductImage[]
  meta          ProductMeta[]
  reviews       Review[]
  orderItems    OrderItem[]
  createdAt     DateTime       @default(now())

  @@map("products")
}

model ProductImage {
  id        Int     @id @default(autoincrement())
  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  imgUrl    String

  @@map("product_images")
}

model ProductMeta {
  id        Int     @id @default(autoincrement())
  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  metaType  String // "tag" or "feature"
  value     String

  @@map("product_meta")
}

model Review {
  id           Int      @id @default(autoincrement())
  productId    Int
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId       Int?
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  customerName String
  title        String?
  img          String?
  createdAt    DateTime @default(now())

  @@map("reviews")
}

model Order {
  id             Int         @id @default(autoincrement())
  userId         Int?
  user           User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  email          String
  customerName   String
  address        String
  phone          String
  status         String      @default("pending") // pending, shipping, delivered
  method         String      @default("Cash on delivery")
  deliveryCharge Float       @default(0.0)
  total          Float
  items          OrderItem[]
  createdAt      DateTime    @default(now())

  @@map("orders")
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId Int?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  title     String
  price     Float
  quantity  Int

  @@map("order_items")
}