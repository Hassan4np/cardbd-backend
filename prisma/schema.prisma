datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String    @id @default(uuid())
  name         String
  email        String    @unique
  phone        String?
  passwordHash String
  role         String    @default("user")
  orders       Order[]
  reviews      Review[]
  createdAt    DateTime  @default(now())

  @@map("users")
}

model Category {
  id       String    @id @default(uuid())
  name     String    @unique
  img      String?
  products Product[]

  @@map("categories")
}

model Product {
  id            String         @id @default(uuid())
  title         String
  subtitle      String?
  price         Float
  oldPrice      Float?
  brand         String         @default("Non-Brand")
  discount      Int            @default(0)
  offer         Int            @default(0)
  rating        Float          @default(0.0)
  des           String?
  reviewCount   Int            @default(0)
  questionCount Int            @default(0)
  sold          Int            @default(0)
  badge         String?
  endsIn        String?
  img           String
  categoryId    String?
  category      Category?      @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  subImages     ProductImage[]
  meta          ProductMeta[]
  reviews       Review[]
  orderItems    OrderItem[]
  createdAt     DateTime       @default(now())

  @@map("products")
}

model ProductImage {
  id        String  @id @default(uuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  imgUrl    String

  @@map("product_images")
}

model ProductMeta {
  id        String  @id @default(uuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  metaType  String
  value     String

  @@map("product_meta")
}

model Review {
  id           String   @id @default(uuid())
  productId    String
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId       String?
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  customerName String
  title        String?
  img          String?
  createdAt    DateTime @default(now())

  @@map("reviews")
}

model Order {
  id             String      @id @default(uuid())
  userId         String?
  user           User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  email          String
  customerName   String
  address        String
  phone          String
  status         String      @default("pending")
  method         String      @default("Cash on delivery")
  deliveryCharge Float       @default(0.0)
  total          Float
  items          OrderItem[]
  createdAt      DateTime    @default(now())

  @@map("orders")
}

model OrderItem {
  id        String   @id @default(uuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  title     String
  price     Float
  quantity  Int

  @@map("order_items")
}